app.js
const socket = io("http://localhost:3000");

let currentRoom;

function createRoom() {
  const name = document.getElementById("name").value;

  socket.emit("createRoom", name, (code) => {
    currentRoom = code;
    alert("Room Code: " + code);
  });
}

function joinRoom() {
  const name = document.getElementById("name").value;
  const code = document.getElementById("roomCode").value;

  socket.emit("joinRoom", { code, username: name }, (err) => {
    if (err) alert(err);
    else currentRoom = code;
  });
}

socket.on("question", (data) => {
  const gameDiv = document.getElementById("game");

  gameDiv.innerHTML = `<h2>${data.question}</h2>`;

  data.options.forEach((opt, i) => {
    const btn = document.createElement("button");
    btn.innerText = opt;
    btn.onclick = () => {
      socket.emit("answer", {
        code: currentRoom,
        answerIndex: i
      });
    };
    gameDiv.appendChild(btn);
  });
});

socket.on("gameOver", (players) => {
  let html = "<h2>Game Over</h2>";
  for (let id in players) {
    html += `<p>${players[id].username}: ${players[id].score}</p>`;
  }
  document.getElementById("game").innerHTML = html;
}); 
